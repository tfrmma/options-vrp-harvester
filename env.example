# API endpoints
DERIVE_BASE_URL=https://api-demo.lyra.finance
DERIVE_WS_URL=wss://api-demo.lyra.finance/ws
# mainnet: https://api.lyra.finance / wss://api.lyra.finance/ws

# Auth (required for live only)
WALLET_PRIVATE_KEY=          # session key private key -- never commit
WALLET_ADDRESS=              # session key address (EOA)
SUBACCOUNT_ID=               # your Derive subaccount ID

# Derive-specific live fields
DERIVE_WALLET_ADDRESS=       # smart contract wallet on Derive Chain
                             # NOT your EOA -- find it: Home > Developers > "Derive Wallet"
DERIVE_DOMAIN_SEPARATOR=     # from docs.derive.xyz/reference/protocol-constants

# Strategy
UNDERLYING=ETH
MODE=paper                   # paper | live

# Capital
TOTAL_CAPITAL_USD=2000
MAX_POSITION_PCT=0.25
MAX_PORTFOLIO_DELTA=0.25
MAX_DRAWDOWN_PCT=0.15
MARGIN_BUFFER_PCT=0.30

# Credit leg (Iron Condor)
CREDIT_DTE_MIN=7
CREDIT_DTE_MAX=14
CREDIT_DELTA_TARGET=0.18
CREDIT_CLOSE_PCT=0.55

# Debit leg (Calendar)
DEBIT_DTE_MIN=30
DEBIT_DTE_MAX=45
DEBIT_PREMIUM_ALLOC=0.45

# Signal
VRP_THRESHOLD=3.0

# Logging
LOG_LEVEL=INFO
