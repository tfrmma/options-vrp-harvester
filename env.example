# ============================================================
#  Derive Bot — Environment Configuration
# ============================================================

# --- API Endpoints ---
DERIVE_BASE_URL=https://api-demo.lyra.finance        # testnet (change to https://api.lyra.finance for mainnet)
DERIVE_WS_URL=wss://api-demo.lyra.finance/ws         # testnet WS

# --- Authentication (required for live trading only) ---
WALLET_PRIVATE_KEY=                                   # your EVM wallet private key (never commit this)
WALLET_ADDRESS=                                       # your EVM wallet address
SUBACCOUNT_ID=                                        # your Derive subaccount ID

# --- Strategy Parameters ---
UNDERLYING=ETH
MODE=paper                                            # paper | live

# --- Capital & Sizing ---
TOTAL_CAPITAL_USD=2000
MAX_POSITION_PCT=0.25                                 # max 25% of capital per strategy leg
MAX_PORTFOLIO_DELTA=0.25                              # |net delta| threshold before hedge

# --- Credit Leg (Iron Condor) ---
CREDIT_DTE_MIN=7
CREDIT_DTE_MAX=14
CREDIT_DELTA_TARGET=0.18                              # target delta for short strikes
CREDIT_CLOSE_PCT=0.55                                 # close at 55% of max profit

# --- Debit Leg (Calendar / Long OTM) ---
DEBIT_DTE_MIN=30
DEBIT_DTE_MAX=45
DEBIT_PREMIUM_ALLOC=0.45                              # 45% of net credit recycled to debit

# --- VRP Filter ---
VRP_THRESHOLD=3.0                                     # min IV - RV gap (vol points) to open credit

# --- Risk ---
MAX_DRAWDOWN_PCT=0.15                                 # halt if drawdown > 15%
MARGIN_BUFFER_PCT=0.30                                # keep 30% capital as margin buffer

# --- Logging ---
LOG_LEVEL=INFO
